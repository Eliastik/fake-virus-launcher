{
  "name": "fake-virus-pack",
  "version": "2.1.2",
  "main": "app.js",
  "scripts": {
    "ng": "ng",
    "dev": "ng serve",
    "build": "ng build --base-href ./",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "localize": "ng extract-i18n --format=json",
    "neu-run": "ng build --base-href ./ && neu run",
    "neu-build": "ng build --base-href ./ && neu build --embed-resources",
    "neu-update": "neu update --latest",
    "neu-version": "neu version",
    "neu-set-icon": "resedit dist/virus-launcher/virus-launcher-win_x64.exe dist/virus-launcher/virus-launcher-win_x64-with-icon.exe --icon 1,resources/icon.ico --sign --pfx cert/certificate.pfx --password \"\""
  },
  "private": true,
  "devDependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/build": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/cli": "~22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/localize": "^22.0.0",
    "@angular/material": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@fontsource/roboto": "^5.2.10",
    "@material-design-icons/font": "^0.14.15",
    "@neutralinojs/lib": "^6.8.0",
    "@neutralinojs/neu": "^11.7.2",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@types/jasmine": "~6.0.0",
    "@zip.js/zip.js": "^2.8.26",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~6.3.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "patch-package": "^8.0.1",
    "resedit-cli": "^3.1.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "typescript": "~6.0.3",
    "zone.js": "~0.16.2"
